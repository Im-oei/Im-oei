rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ORDERS =====
    // ลูกค้า login แล้ว → สร้าง/อ่านได้โดยตรง (ไม่ผ่าน Cloud Function แล้ว)
    // admin → แก้ไข/ลบได้
    match /orders/{orderId} {
      allow create: if request.auth != null;
      allow read:   if request.auth != null;
      allow update: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
      allow delete: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== MENU =====
    match /menu/{itemId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== CATEGORIES =====
    match /categories/{catId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== BANNERS =====
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== STAMPS =====
    // ลูกค้า login แล้ว → อ่าน/เขียนได้ (update แต้มสะสมโดยตรง)
    match /stamps/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== SETTINGS =====
    match /settings/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== PUSH SUBSCRIPTIONS =====
    match /pushSubscriptions/{phone} {
      allow read: if request.auth != null;
      allow write: if request.auth != null;
    }

    // ===== PUSH QUEUE =====
    match /pushQueue/{docId} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ===== LINE QUEUE =====
    match /lineQueue/{docId} {
      allow read: if false;
      allow write: if request.auth != null;
    }

    // ===== RATINGS =====
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== STORE CONFIG =====
    match /store/{docId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== CUSTOMERS =====
    match /customers/{customerId} {
      allow read: if request.auth != null;
      allow create: if true;
      allow update: if request.auth != null;
      allow delete: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }

    // ===== PICKUP LOCATIONS =====
    match /pickupLocations/{locId} {
      allow read: if true;
      allow write: if request.auth != null &&
        (request.auth.token.admin == true || request.auth.token.owner == true);
    }
  }
}
