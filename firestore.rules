rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ===== ORDERS =====
    match /orders/{orderId} {
      allow create: if isLoggedIn();   // ลูกค้าสั่งได้
      allow read: if isLoggedIn();

      // ❗ แก้ / ลบ → admin เท่านั้น
      allow update, delete: if isAdmin();
    }

    // ===== MENU =====
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== CATEGORIES =====
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== BANNERS =====
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== STAMPS =====
    match /stamps/{phone} {
      allow read, write: if isAdmin();
    }

    // ===== SETTINGS =====
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== PUSH QUEUE =====
    match /pushQueue/{docId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    // ===== LINE QUEUE =====
    match /lineQueue/{docId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    // ===== RATINGS =====
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ===== CUSTOMERS =====
    match /customers/{customerId} {
      allow read, write: if isAdmin();
    }

    // ===== PICKUP LOCATIONS =====
    match /pickupLocations/{locId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== LINE USERS =====
    match /lineUsers/{userId} {
      allow read: if isLoggedIn();
      allow create: if isLoggedIn();
      allow update: if request.auth.uid == userId;
      allow delete: if false;
    }

    // ===== LINE PHONE MAP =====
    match /linePhoneMap/{phone} {
      allow read: if isAdmin();
      allow write: if isAdmin();
    }

    // ===== ADMINS =====
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // 🚫 ปิดทุกอย่างที่ไม่ได้กำหนด
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
