rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ORDERS =====
    // ระบบใช้ sessionStorage (ไม่มี Firebase Auth) → อนุญาต create/read โดยไม่ต้อง auth
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // ===== MENU =====
    match /menu/{itemId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== CATEGORIES =====
    match /categories/{catId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== BANNERS =====
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== STAMPS =====
    match /stamps/{phone} {
      allow read: if true;
      allow write: if true;
    }

    // ===== SETTINGS =====
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PUSH SUBSCRIPTIONS =====
    match /pushSubscriptions/{phone} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PUSH QUEUE =====
    match /pushQueue/{docId} {
      allow read: if false;
      allow write: if true;
    }

    // ===== LINE QUEUE =====
    match /lineQueue/{docId} {
      allow read: if false;
      allow write: if true;
    }

    // ===== RATINGS =====
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // ===== STORE CONFIG =====
    match /store/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== CUSTOMERS =====
    match /customers/{customerId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PICKUP LOCATIONS =====
    match /pickupLocations/{locId} {
      allow read: if true;
      allow write: if true;
    }
  }
}
