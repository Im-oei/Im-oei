rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // ===== ORDERS =====
    match /orders/{orderId} {
      allow create: if true;
      allow read:   if true;
      allow update: if true;
      allow delete: if request.auth != null;
    }

    // ===== MENU =====
    match /menu/{itemId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== CATEGORIES =====
    match /categories/{catId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== BANNERS =====
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== STAMPS =====
    match /stamps/{phone} {
      allow read: if true;
      allow write: if true;
    }

    // ===== SETTINGS =====
    match /settings/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PUSH SUBSCRIPTIONS =====
    match /pushSubscriptions/{phone} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PUSH QUEUE =====
    match /pushQueue/{docId} {
      allow read: if false;
      allow write: if true;
    }

    // ===== LINE QUEUE =====
    match /lineQueue/{docId} {
      allow read: if false;
      allow write: if true;
    }

    // ===== RATINGS =====
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if true;
      allow update, delete: if true;
    }

    // ===== STORE CONFIG =====
    match /store/{docId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== CUSTOMERS =====
    match /customers/{customerId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== PICKUP LOCATIONS =====
    match /pickupLocations/{locId} {
      allow read: if true;
      allow write: if true;
    }

    // ===== LINE USERS (LIFF) =====
    // เก็บ { userId, displayName, pictureUrl, phone, linkedAt }
    // liff.html เขียน/อ่าน document โดยใช้ userId เป็น key
    match /lineUsers/{userId} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

    // ===== LINE PHONE MAP (LIFF) =====
    // index: phone → userId  ให้ Cloud Function/admin ค้นหา userId จากเบอร์ได้เร็ว
    // เก็บ { userId, displayName, pictureUrl, updatedAt }
    match /linePhoneMap/{phone} {
      allow read:   if true;
      allow create: if true;
      allow update: if true;
      allow delete: if false;
    }

  }
}
