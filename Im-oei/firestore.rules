rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isLoggedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isLoggedIn() &&
        exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }

    // ===== ORDERS =====
    // cart.html ไม่มี Firebase Auth → validate จาก data fields แทน
    match /orders/{orderId} {
      // ลูกค้าสร้าง order ได้ ถ้ามี fields ที่จำเป็นครบ
      allow create: if request.resource.data.keys().hasAll(['items','total','customerPhone','status','createdAt'])
        && request.resource.data.status == 'pending'
        && request.resource.data.total is number
        && request.resource.data.total > 0;
      // อ่าน: admin หรือ login แล้ว (สำหรับ success.html / orders.html)
      allow read: if isAdmin() || isLoggedIn() || true; // TODO: จำกัดในอนาคตเมื่อมี Firebase Auth

      // ❗ แก้ / ลบ → admin เท่านั้น
      allow update, delete: if isAdmin();
    }

    // ===== MENU =====
    match /menu/{itemId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== CATEGORIES =====
    match /categories/{catId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== BANNERS =====
    match /banners/{bannerId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== SETTINGS =====
    match /settings/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== PUSH QUEUE =====
    match /pushQueue/{docId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    // ===== LINE QUEUE =====
    match /lineQueue/{docId} {
      allow read: if false;
      allow write: if isAdmin();
    }

    // ===== RATINGS =====
    match /ratings/{ratingId} {
      allow read: if true;
      allow create: if isLoggedIn();
      allow update, delete: if isAdmin();
    }

    // ===== CUSTOMERS =====
    match /customers/{customerId} {
      allow read, write: if isAdmin();
    }

    // ===== PICKUP LOCATIONS =====
    match /pickupLocations/{locId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // ===== LINE USERS =====
    // LIFF ไม่มี Firebase Auth → ยอมให้อ่าน/เขียนได้โดยตรง (validate ด้วย data)
    match /lineUsers/{userId} {
      // อ่านได้เฉพาะ document ของตัวเอง (LIFF ส่ง userId มาใน path)
      // หรือ admin อ่านได้ทั้งหมด
      allow read: if true;  // LIFF อ่าน doc ตัวเองก่อน check ว่าเคยผูกหรือยัง
      // ลูกค้า LIFF เขียนได้ เฉพาะ document ของตัวเอง (userId ใน path ต้องตรงกับ field ใน data)
      allow create: if request.resource.data.userId == userId
        && request.resource.data.keys().hasAll(['userId','displayName','phone','linkedAt','updatedAt']);
      allow update: if (isLoggedIn() && request.auth.uid == userId)
        || request.resource.data.userId == userId;
      allow delete: if false;
    }

    // ===== LINE PHONE MAP =====
    // Cloud Function และ LIFF เขียนได้ (ไม่มี sensitive data, อ่านเฉพาะ admin)
    match /linePhoneMap/{phone} {
      allow read: if isAdmin();
      // ลูกค้า LIFF สร้าง/อัปเดต mapping ของตัวเองได้
      allow create, update: if request.resource.data.userId is string
        && request.resource.data.userId.size() > 0;
      allow delete: if isAdmin();
    }

    // ===== ADMINS =====
    match /admins/{uid} {
      allow read: if request.auth != null && request.auth.uid == uid;
      allow write: if false;
    }

    // ===== REWARDS CATALOG =====
    match /rewards/{rewardId} {
      allow read: if true;                    // ลูกค้าดูได้
      allow write: if isAdmin();
    }

    // ===== REWARD REDEMPTIONS =====
    match /rewardRedemptions/{docId} {
      allow read: if isAdmin();
      allow create: if isLoggedIn();          // ลูกค้าแลกได้
      allow update: if isAdmin();             // admin อนุมัติ/ปฏิเสธ
      allow delete: if false;
    }

    // ===== STAMPS =====
    // cart.html เขียนแต้มหลังสั่งซื้อ ไม่มี Firebase Auth
    match /stamps/{phone} {
      allow read: if isLoggedIn() || true; // อ่านได้ (sync แต้มในหน้า cart)
      allow write: if isAdmin() ||
        (isLoggedIn() && request.auth.token.phone_number == phone) ||
        // LIFF/cart ไม่มี Auth → validate phone field ใน data
        (request.resource.data.phone == phone && request.resource.data.keys().hasAll(['phone','updatedAt']));
    }

    // ===== PUSH SUBSCRIPTIONS =====
    match /pushSubscriptions/{phone} {
      // ลูกค้าเขียน subscription ของตัวเองได้, admin อ่านได้ทั้งหมด
      allow read: if isAdmin();
      allow write: if isAdmin() ||
        (isLoggedIn() && request.auth.token.phone_number == phone);
    }

    // 🚫 ปิดทุกอย่างที่ไม่ได้กำหนด
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
